# Copy this to .streamlit/secrets.toml and fill in your values
# (secrets.toml is gitignored — never commit your actual token)

GITHUB_TOKEN  = "ghp_xxxxxxxxxxxxxxxxxxxx"
GITHUB_REPO   = "mrdanielvlip-byte/companies-datascrape"

# Password-protect the app (leave blank or remove to disable)
APP_PASSWORD  = "your-password-here"

# Optional: Enable AI search assistant (natural language → form config)
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxx"
